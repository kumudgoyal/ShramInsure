# ShramInsure Backend Environment Configuration
# Copy to .env and fill in your keys. System works fully without keys (mock fallback).

# ── Server ────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
JWT_SECRET=shraminsure_super_secret_jwt_key_2026

# ── Weather API (OpenWeatherMap) ──────────────────────────
# Get free key: https://openweathermap.org/api
# Leave blank to use realistic mock data
OPENWEATHER_API_KEY=

# ── AQI API (WAQI - World Air Quality Index) ──────────────
# Get free key: https://aqicn.org/data-platform/token/
# Leave blank to use realistic mock data
WAQI_API_KEY=

# ── Geocoding (OpenCage) ──────────────────────────────────
# Get free key: https://opencagedata.com/api
# Used for reverse geocoding lat/lng → city
GEO_API_KEY=

# ── Payment (Razorpay) ────────────────────────────────────
# Get keys: https://razorpay.com/
# Leave blank to use simulation mode
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# ── Database ──────────────────────────────────────────────
DB_PATH=./shraminsure.db
